      #   log_message "INFO" "NO custom deployment detected"
      #   else
      #   log_message "INFO" "Custom deployment detected"
      # fi
      

      if [ "$DEPLOY_TYPE" == "statefull" ] && [ "$CUSTOM_DEPLOYMENT" == "-" ] ; then
          log_message "INFO" "Deployment type is *** $DEPLOY_TYPE ***  execution will only upgrade "
          HELM_COMMAND="helm --kubeconfig $KC -n "$NAMESPACE" upgrade "$RELEASE_NAME" "$CHART_REPO" -f "$CHART_REPO/$VALUES_FILE""
          #HELM_COMMAND="echo hello from a statefull deployment "
        else
