# Function to check pod health and to make sure pods of a given release are in running state 
# This script will terminate if the pods are not running for more than 20 minutes, which is something that should ideally not happen.
check_pod_status() {
  RELEASE_NAME=$1
  NAMESPACE=$(yq e '.ns' $3)
  KC=$(yq e '.kc' $3)
  log_message "INFO" "Checking for pods status with ( RELEASE_NAME: $RELEASE_NAME, NAMESPACE: $NAMESPACE,  KUBECONFIG: $KC )"
  START_TIME=$(date +%s)
  while true; do
    CURRENT_TIME=$(date +%s)
    ELAPSED_TIME=$((CURRENT_TIME - START_TIME))
    if [[ $ELAPSED_TIME -gt 1200 ]]; then
      log_message "INFO" "##############################"
      log_message "ERROR" "Pods for release $RELEASE_NAME are not in Running state for more than 20 minutes. Exiting"
      log_message "ERROR" "Error code: 2"
      log_message "INFO" "##############################"s
      exit 2
    fi
    TOTAL_PODS=$(kubectl --kubeconfig $KC --namespace $NAMESPACE get pods  |grep $RELEASE_NAME  | wc -l)
    if [[ $TOTAL_PODS == "0" ]]; then
      log_message "INFO" "##############################"
      log_message "ERROR" "There are no pods for $RELEASE_NAME"
      log_message "ERROR" "Error code: 3"
      log_message "INFO" "##############################"
      #exit 3
    else
      POD_STATUS=$(kubectl --kubeconfig $KC -n $NAMESPACE get pods  | grep $RELEASE_NAME  | awk -F " " '{print $2}' | grep -vi running | wc -l)
      if [[ $POD_STATUS != "0" ]]; then
        log_message "INFO" "All Pods for release $RELEASE_NAME are in Running state"
        log_message "INFO" "Amount of running Pods for release $RELEASE_NAME are $POD_STATUS"
        POD_AMOUNT=$(kubectl --kubeconfig $KC get pods -n $NAMESPACE | grep $RELEASE_NAME | awk -F " " '{print $2}' | grep -vi running | wc -l)
        log_message "INFO" "Running Pods are : $POD_AMOUNT"
        log_message "INFO" "##############################"
        log_message "INFO" "##############################"

        break
      else
        log_message "WARN" "Pods for release $RELEASE_NAME are not yet in Running state, checking again in 5 seconds"
        log_message "INFO" "Amount of running Pods for release $RELEASE_NAME are $POD_STATUS"
        POD_AMOUNT=$(kubectl --kubeconfig $KC get pods -n $NAMESPACE | grep $RELEASE_NAME | awk -F " " '{print $2}' | grep -vi running | wc -l)
        log_message "INFO" "Running Pods are : $POD_AMOUNT"
        log_message "INFO" "##############################"
        log_message "INFO" "##############################"
        sleep 5
      fi            
      log_message "WARN" "Pods for release $RELEASE_NAME are not yet in Running state, checking again in 5 seconds"
      sleep 5
    fi
  done
}
