    helm --kubeconfig $KC uninstall "$RELEASE_NAME" -n "$NAMESPACE" >> "$LOG_FILE" 2>&1

  else
    eea-deployer "Uh-oh! something is wrong"  
    log_message "INFO" "Usage: $0 [OPTIONS] [ARGUMENTS - Optional]"
