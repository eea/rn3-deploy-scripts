# Source: helm/templates/pgpool/deployment.yaml
apiVersion: apps/v1
kind: Deployment
metadata:
  name: rn3-pg-helm-pgpool
  labels: 
    app.kubernetes.io/name: helm
    helm.sh/chart: helm-2.2.2
    app.kubernetes.io/instance: rn3-pg-helm
    app.kubernetes.io/managed-by: Helm
    app.kubernetes.io/component: pgpool
spec:
  replicas: 1
  selector:
    matchLabels: 
      app.kubernetes.io/name: helm
      app.kubernetes.io/instance: rn3-pg-helm
      app.kubernetes.io/component: pgpool
  template:
    metadata:
      labels: 
        app.kubernetes.io/name: helm
        helm.sh/chart: helm-2.2.2
        app.kubernetes.io/instance: rn3-pg-helm
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/component: pgpool
    spec:      
      priorityClassName: 
      securityContext:
        fsGroup: 1001
      # Auxiliar vars to populate environment variables
      containers:
        - name: pgpool
          image: docker.io/bitnamilegacy/pgpool:4.1.1
          imagePullPolicy: "IfNotPresent"
          securityContext:
            runAsUser: 1001
          env:
            - name: BITNAMI_DEBUG
              value: "false"
            - name: PGPOOL_BACKEND_NODES
              value: 0:rn3-pg-helm-postgresql-0.rn3-pg-helm-postgresql-headless.reportnet.svc.cluster.local:5432,1:rn3-pg-helm-postgresql-1.rn3-pg-helm-postgresql-headless.reportnet.svc.cluster.local:5432,2:rn3-pg-helm-postgresql-2.rn3-pg-helm-postgresql-headless.reportnet.svc.cluster.local:5432,
            - name: PGPOOL_SR_CHECK_USER
              value: "repmgr"
            - name: PGPOOL_SR_CHECK_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: pg-secret
                  key: repmgr-password
            - name: PGPOOL_ENABLE_LOAD_BALANCING
              value: "yes"
            - name: PGPOOL_ENABLE_LDAP
              value: "no"
            - name: PGPOOL_POSTGRES_USERNAME
              value: "postgres"
            - name: PGPOOL_POSTGRES_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: pg-secret
                  key: postgresql-password
            - name: PGPOOL_ADMIN_USERNAME
              value: "admin"
            - name: PGPOOL_ADMIN_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: pg-secret
                  key: admin-password
          ports:
            - name: postgresql
              containerPort: 5432
              protocol: TCP
          resources:
            limits:
              memory: 1Gi
            requests:
              memory: 1Gi
          volumeMounts:
            - name: custom-init-scripts
              mountPath: /docker-entrypoint-initdb.d/
      volumes:
        - name: custom-init-scripts
          configMap:
            name: rn3-pg-helm-pgpool-initdb-scripts
---
# Source: helm/templates/postgresql/statefulset.yaml
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: rn3-pg-helm-postgresql
  labels:
    app.kubernetes.io/name: helm
    helm.sh/chart: helm-2.2.2
    app.kubernetes.io/instance: rn3-pg-helm
    app.kubernetes.io/managed-by: Helm
    app.kubernetes.io/component: postgresql
spec:
  serviceName: rn3-pg-helm-postgresql-headless
  replicas: 3
  updateStrategy:
    type: RollingUpdate
  selector:
    matchLabels:
      app.kubernetes.io/name: helm
      app.kubernetes.io/instance: rn3-pg-helm
      app.kubernetes.io/component: postgresql
  template:
    metadata:
      labels:
        app.kubernetes.io/name: helm
        helm.sh/chart: helm-2.2.2
        app.kubernetes.io/instance: rn3-pg-helm
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/component: postgresql
    spec:      
      priorityClassName: 
      securityContext:
        fsGroup: 1001
      containers:
        - name: postgresql
          image: docker.io/bitnamilegacy/postgresql:11.7.0
          imagePullPolicy: "IfNotPresent"
          securityContext:
            runAsUser: 1001
          # Auxiliar vars to populate environment variables
          env:
            - name: BITNAMI_DEBUG
              value: "false"
            # PostgreSQL configuration
            - name: POSTGRESQL_VOLUME_DIR
              value: "/bitnami/postgresql"
            - name: PGDATA
              value: "/bitnami/postgresql/data"
            - name: POSTGRES_USER
              value: "postgres"
            - name: POSTGRES_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: pg-secret
                  key: postgresql-password
            - name: POSTGRES_DB
              value: "postgres"
            # Repmgr configuration
            - name: MY_POD_NAME
              valueFrom:
                fieldRef:
                  fieldPath: metadata.name
            - name: REPMGR_UPGRADE_EXTENSION
              value: "no"
            - name: REPMGR_PGHBA_TRUST_ALL
              value: "no"
            - name: REPMGR_MOUNTED_CONF_DIR
              value: "/bitnami/repmgr/conf"
            - name: REPMGR_PARTNER_NODES
              value: rn3-pg-helm-postgresql-0.rn3-pg-helm-postgresql-headless.reportnet.svc.cluster.local,rn3-pg-helm-postgresql-1.rn3-pg-helm-postgresql-headless.reportnet.svc.cluster.local,rn3-pg-helm-postgresql-2.rn3-pg-helm-postgresql-headless.reportnet.svc.cluster.local,
            - name: REPMGR_PRIMARY_HOST
              value: "rn3-pg-helm-postgresql-0.rn3-pg-helm-postgresql-headless.reportnet.svc.cluster.local"
            - name: REPMGR_NODE_NAME
              value: "$(MY_POD_NAME)"
            - name: REPMGR_NODE_NETWORK_NAME
              value: "$(MY_POD_NAME).rn3-pg-helm-postgresql-headless.reportnet.svc.cluster.local"
            - name: REPMGR_LOG_LEVEL
              value: "NOTICE"
            - name: REPMGR_CONNECT_TIMEOUT
              value: "5"
            - name: REPMGR_RECONNECT_ATTEMPTS
              value: "3"
            - name: REPMGR_RECONNECT_INTERVAL
              value: "5"
            - name: REPMGR_USERNAME
              value: "repmgr"
            - name: REPMGR_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: pg-secret
                  key: repmgr-password
            - name: REPMGR_DATABASE
              value: "repmgr"
          ports:
            - name: postgresql
              containerPort: 5432
              protocol: TCP
          livenessProbe:
            exec:
              command:
                - sh
                - -c
                - 'PGPASSWORD=$POSTGRES_PASSWORD psql -w -U "postgres" -d "postgres"  -h 127.0.0.1 -c "SELECT 1"'
            initialDelaySeconds: 30
            periodSeconds: 10
            timeoutSeconds: 5
            successThreshold: 1
            failureThreshold: 6
          readinessProbe:
            exec:
              command:
                - sh
                - -c
                - 'PGPASSWORD=$POSTGRES_PASSWORD psql -w -U "postgres" -d "postgres"  -h 127.0.0.1 -c "SELECT 1"'
            initialDelaySeconds: 5
            periodSeconds: 10
            timeoutSeconds: 5
            successThreshold: 1
            failureThreshold: 6
          resources:
            limits:
              memory: 14Gi
            requests:
              memory: 14Gi
          volumeMounts:
            - name: custom-init-scripts
              mountPath: /docker-entrypoint-initdb.d/
            - name: data
              mountPath: /bitnami/postgresql
        - name: metrics
          image: docker.io/bitnami/postgres-exporter:latest
          imagePullPolicy: "IfNotPresent"
          securityContext:
            runAsUser: 1001
          env:
            - name: DATA_SOURCE_URI
              value: "127.0.0.1:5432/postgres?sslmode=disable"
            - name: DATA_SOURCE_PASS
              valueFrom:
                secretKeyRef:
                  name: pg-secret
                  key: postgresql-password
            - name: DATA_SOURCE_USER
              value: "postgres"
          ports:
            - name: metrics
              containerPort: 9187
              protocol: TCP
          livenessProbe:
            httpGet:
              path: /
              port: metrics
            initialDelaySeconds: 30
            periodSeconds: 10
            timeoutSeconds: 5
            successThreshold: 1
            failureThreshold: 6
          readinessProbe:
            httpGet:
              path: /
              port: metrics
            initialDelaySeconds: 5
            periodSeconds: 10
            timeoutSeconds: 5
            successThreshold: 1
            failureThreshold: 6
          resources:
            limits:
              cpu: 100m
              memory: 160Mi
            requests:
              cpu: 100m
              memory: 80Mi
          volumeMounts:
      volumes:
        - name: custom-init-scripts
          configMap:
            name: rn3-pg-helm-postgresql-initdb-scripts
  volumeClaimTemplates:
    - metadata:
        name: data
      spec:
